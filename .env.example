# Required in the Vercel project's Environment Variables for the app to work in production.
# Local SQLite (the default when these are unset) only works for local `npm run dev`/`npm run build` —
# Vercel's deployed functions have a read-only filesystem, so Turso is required in production.

# Turso (libsql) database — production database
TURSO_DATABASE_URL="libsql://<your-db>.turso.io"
TURSO_AUTH_TOKEN="<turso-auth-token>"

# Admin panel password (app/actions/admin.ts)
ADMIN_PASSWORD=""

# Monobank merchant API token, used to create payment invoices (lib/monobank.ts)
MONOBANK_TOKEN=""

# Public base URL, used to build Monobank redirect/webhook URLs (lib/monobank.ts)
NEXT_PUBLIC_APP_URL="https://your-domain.example"

# Nova Poshta API key for address/warehouse lookups (lib/novaposhta.ts).
# Optional: the code falls back to an empty key if unset.
NOVA_POSHTA_API_KEY=""

# Optional: overrides the default Google Tag Manager container id (app/layout.tsx)
NEXT_PUBLIC_GTM_ID=""

# Local development only (ignored when TURSO_DATABASE_URL is set)
DATABASE_URL="file:./dev.db"
